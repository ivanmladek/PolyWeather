          "expr": "(sum(increase(polyweather_source_requests_total{outcome!~\"success|cache_hit\"}[15m])) / clamp_min(sum(increase(polyweather_source_requests_total[15m])), 1))",
          "refId": "A"
        }
      ],
      "title": "Source Error Rate (15m)",
      "type": "stat"
